name: Kernel-Soberano-Online

on:
  schedule:
    - cron: '0 0 * * *' # Sincronia XT: Executa a cada 24 horas
  workflow_dispatch: # Permite rodar manualmente

jobs:
  contingencia:
    runs-on: ubuntu-latest # Impedância Zero
    steps:
      - name: Checkout Hardware
        uses: actions/checkout@v4

      - name: Higiene de Dados
        run: |
          echo "Limpando dízimas decimais e arquivos porosos..."
          find . -name "*.dizima" -type f -delete
          find . -name "*.tmp" -type f -delete
          echo "Matriz de Soberania Protegida."
