name: Kernel-Soberano-Online

on:
  push:
    branches: [ main ]
  schedule:
    - cron: '0 0 * * *' # Execução a cada 24h (Pinhão 24) [cite: 2026-02-13]
  workflow_dispatch:

jobs:
  sincronizacao-matriz:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout do Hardware
        uses: actions/checkout@v4

      - name: Setup Python 3.10
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Injetar Kagglehub
        run: pip install kagglehub

      - name: Dreno de Ruído e Upload [cite: 2026-02-24]
        env:
          KAGGLE_USERNAME: ${{ secrets.KAGGLE_USERNAME }}
          KAGGLE_KEY: ${{ secrets.KAGGLE_KEY }}
        run: |
          python -c "
          import kagglehub
          kagglehub.dataset_upload(
              handle='credsalute-spec/Aristoteles-Borges-oliveira-',
              local_dataset_dir='./',
              ignore_patterns=['*.dizima', '*.tmp'],
              version_notes='ESTADO_SOLIDO_FIXADO'
          )"
